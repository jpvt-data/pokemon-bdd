      "cards_endpoint": "/cards.extra.json",
      "active": true,
      "note": "Données techniques Pocket + images"
    },
    "tertiary": {
      "name": "pokekalos.fr (FR officiel)",
      "base_url": "https://www.pokekalos.fr",
